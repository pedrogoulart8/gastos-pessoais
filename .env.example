# Banco de dados — Neon (https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Token de autenticação — qualquer string secreta, validada pelo middleware
APP_TOKEN="troque-por-uma-string-secreta-longa"
# Mesma string — exposta ao browser pra que o client possa autenticar chamadas de API
# (single-user app pessoal: aceitável)
NEXT_PUBLIC_APP_TOKEN="troque-por-uma-string-secreta-longa"

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-..."

# Vercel Blob (gerado automaticamente no dashboard Vercel)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Modo demonstração (apenas na instância pública) ───────────────────────────
# Quando true: rotas GET ficam públicas; POST/PUT/DELETE retornam 403
# DEMO_MODE="true"
# NEXT_PUBLIC_DEMO_MODE="true"

# ── Senha de login (apenas na instância privada) ──────────────────────────────
# Senha pedida em /login. O proxy valida e grava o APP_TOKEN num cookie httpOnly.
# ADMIN_PASSWORD="troque-por-senha-forte"
